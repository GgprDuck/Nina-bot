generator client {
  provider = "prisma-client-js" 
  url      = env("DATABASE_URL") 
}

datasource db {
  provider = "postgresql"
}

model ShoppingList {
  id             String   @id @default(uuid())
  title          String   @unique
  shopName       String
  kindOfDiscount String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Recipe {
  id             String   @id @default(uuid())
  title          String   
  ingredients    String[]
  instructions   String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Spendings {
  id             String   @id @default(uuid())
  category       String
  amount         Float
  description    String?
  currency       String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}